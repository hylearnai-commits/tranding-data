[Unit]
Description=Trading Data Center API
After=network.target

[Service]
Type=simple
WorkingDirectory=/opt/tranding-data
EnvironmentFile=/opt/tranding-data/.env
ExecStart=/usr/bin/python3 -m uvicorn app.main:app --host 0.0.0.0 --port 8099
Restart=always
RestartSec=5
User=www-data
Group=www-data

[Install]
WantedBy=multi-user.target
